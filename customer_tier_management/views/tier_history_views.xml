<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_customer_tier_history_tree" model="ir.ui.view">
        <field name="name">customer.tier.history.tree</field>
        <field name="model">customer.tier.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="change_date"/>
                <field name="partner_id"/>
                <field name="old_tier_id"/>
                <field name="new_tier_id"/>
                <field name="reason"/>
                <field name="triggered_by_user_id"/>
            </list>
        </field>
    </record>

    <record id="action_customer_tier_history" model="ir.actions.act_window">
        <field name="name">Tier Change History</field>
        <field name="res_model">customer.tier.history</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
