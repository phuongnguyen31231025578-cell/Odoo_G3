<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_customer_tier_tree" model="ir.ui.view">
        <field name="name">customer.tier.tree</field>
        <field name="model">customer.tier</field>
        <field name="arch" type="xml">
            <list default_order="min_points asc">
                <field name="sequence"/>
                <field name="name"/>
                <field name="min_points"/>
                <field name="auto_discount_percent"/>
                <field name="color" widget="color_picker"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_customer_tier_form" model="ir.ui.view">
        <field name="name">customer.tier.form</field>
        <field name="model">customer.tier</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="min_points"/>
                            <field name="auto_discount_percent"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_customer_tier" model="ir.actions.act_window">
        <field name="name">Cấp độ thành viên</field>
        <field name="res_model">customer.tier</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
