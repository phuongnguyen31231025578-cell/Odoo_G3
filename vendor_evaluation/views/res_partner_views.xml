<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Bổ sung tab "Đánh giá uy tín" lên form Nhà cung cấp -->
    <record id="vendor_evaluation_partner_form_view" model="ir.ui.view">
        <field name="name">res.partner.form.vendor.evaluation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Đánh giá uy tín NCC" name="vendor_evaluation"
                      invisible="supplier_rank == 0">
                    <field name="supplier_rank" invisible="1"/>
                    <group>
                        <group string="Điểm tổng kết">
                            <field name="x_vendor_rating"
                                   widget="progressbar"
                                   options="{'max_value': 100}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Breakdown 100 điểm">
                            <field name="x_quality_score"/>
                            <field name="x_price_score"/>
                            <field name="x_delivery_score"/>
                        </group>
                    </group>
                    <div class="alert alert-warning" role="alert"
                         invisible="x_vendor_rating >= 40">
                        <strong>⚠️ Cảnh báo:</strong> Nhà cung cấp này có điểm uy tín
                        dưới mức sàn 40 điểm — hệ thống sẽ <strong>chặn xác nhận đơn mua hàng</strong>.
                    </div>
                </page>
            </xpath>

        </field>
    </record>

</odoo>