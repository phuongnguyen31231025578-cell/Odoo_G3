<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="chau_vien_mrp_bom_form_view_v2" model="ir.ui.view">
        <field name="name">chau.vien.mrp.bom.form</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_qty']" position="attributes">
                <attribute name="class">mw-25</attribute>
                <attribute name="style">min-width: 100px !important; width: 100px !important;</attribute>
            </xpath>
            <xpath expr="//label[@for='product_qty']" position="after">
                <label for="expected_waste_rate" string="Tỷ lệ hao hụt dự kiến (%)"/>
            </xpath>
            <xpath expr="//div[hasclass('o_row')][field[@name='product_qty']]" position="after">
                <div class="o_row">
                    <field
                        name="expected_waste_rate"
                        invisible="type == 'phantom'"
                    />
                    <span>%</span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>